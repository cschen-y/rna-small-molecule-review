[74.869 141.074]
[80.609 127.215]
[86.349 113.357]
[80.902 99.931]
[86.446 86.544]
[99.792 80.903]
[100.329 70.838]
[106.835 66.012]
[113.906 52.783]
[120.977 39.554]
[128.048 26.326]
[126.971 9.962]
[140.752 1.073]
[155.215 8.804]
[155.481 25.201]
[141.277 33.396]
[134.206 46.625]
[127.135 59.854]
[120.064 73.083]
[113.651 86.643]
[119.098 100.069]
[113.554 113.456]
[100.208 119.097]
[94.467 132.956]
