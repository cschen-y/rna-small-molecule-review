[66.399 122.744]
[81.706 121.485]
[88.045 107.890]
[87.018 93.946]
[98.360 85.770]
[104.699 72.176]
[111.039 58.581]
[117.378 44.986]
[123.717 31.392]
[114.842 18.857]
[113.440 3.562]
[119.887 -10.378]
[132.450 -19.214]
[147.749 -20.569]
[161.669 -14.078]
[170.465 -1.487]
[171.772 13.816]
[165.237 27.716]
[152.619 36.472]
